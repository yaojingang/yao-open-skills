{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "BayesianDecisionReport",
  "type": "object",
  "required": [
    "title",
    "summary",
    "prior",
    "evidence",
    "posterior",
    "decision",
    "sensitivity",
    "natural_frequency",
    "warnings"
  ],
  "properties": {
    "title": {
      "type": "string"
    },
    "summary": {
      "type": "object",
      "required": [
        "posterior_probability",
        "recommendation",
        "confidence"
      ],
      "properties": {
        "posterior_probability": {
          "type": "number"
        },
        "credible_interval": {
          "type": [
            "array",
            "null"
          ],
          "items": {
            "type": "number"
          },
          "minItems": 2,
          "maxItems": 2
        },
        "recommendation": {
          "type": "string"
        },
        "confidence": {
          "type": "string"
        },
        "decision_ready": {
          "type": [
            "boolean",
            "null"
          ]
        },
        "decision_readiness": {
          "type": [
            "number",
            "null"
          ]
        },
        "decision_status": {
          "type": [
            "string",
            "null"
          ]
        },
        "one_sentence": {
          "type": "string"
        }
      }
    },
    "prior": {
      "type": "object"
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "posterior": {
      "type": "object"
    },
    "decision": {
      "type": "object"
    },
    "sensitivity": {
      "type": "object"
    },
    "natural_frequency": {
      "type": "object"
    },
    "next_information": {
      "type": "object"
    },
    "prior_hygiene": {
      "type": "object",
      "properties": {
        "principles_total": {
          "type": "number"
        },
        "reported_count": {
          "type": "number"
        },
        "selection_rule": {
          "type": "string"
        },
        "checks": {
          "type": "array",
          "items": {
            "type": "object"
          }
        }
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "calculation_log": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "conversation_process": {
      "type": [
        "object",
        "null"
      ]
    }
  }
}
